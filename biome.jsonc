{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    // Exclusions:
    //  - src/index.css: Biome's CSS parser does not understand Tailwind v4's
    //    `@theme` at-rule and reports it as a syntax error.
    //  - scripts/posthog-dashboard.mjs: a standalone, dependency-free utility that
    //    predates this toolchain. docs/ANALYTICS.md tells creators to read it
    //    before running it, so we do not churn it for formatting.
    "includes": [
      "**",
      "!dist",
      "!coverage",
      "!node_modules",
      "!pnpm-lock.yaml",
      "!src/index.css",
      "!scripts/posthog-dashboard.mjs"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      // Enforces the CLAUDE.md conventions that TypeScript alone cannot.
      "suspicious": {
        "noExplicitAny": "error"
      },
      "style": {
        "noDefaultExport": "error",
        "useConst": "error",
        "noNonNullAssertion": "error"
      }
    }
  },
  "overrides": [
    {
      // CLAUDE.md permits default exports only for chai.config.ts and route
      // components. Vite's config is a tool contract and must default-export too.
      "includes": ["chai.config.ts", "src/App.tsx", "vite.config.ts"],
      "linter": { "rules": { "style": { "noDefaultExport": "off" } } }
    },
    {
      // Stripping control characters IS the job of these modules — the sanitiser
      // and the single-line/multi-line config validators each need a literal C0
      // range, and the UPI test matrix embeds them as fixtures.
      "includes": ["src/lib/upi.ts", "src/lib/upi.test.ts", "src/config/schema.ts"],
      "linter": {
        "rules": {
          "suspicious": { "noControlCharactersInRegex": "off" }
        }
      }
    }
  ]
}
