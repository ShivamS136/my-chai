{
  "name": "buy-me-a-chai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A zero-commission, self-hosted Buy Me a Chai page for Indian creators, powered by UPI P2P.",
  "license": "MIT",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:deploy": "pnpm check:placeholder && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:config": "node scripts/check-config.mts",
    "check:placeholder": "node scripts/check-placeholder.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@tailwindcss/vite": "4.3.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.13.3",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.3",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
